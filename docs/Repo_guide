└── koroporo-jira/
    ├── database/                # (Đã có) Chứa các file SQL logic xử lý Database[cite: 1]
    │   ├── 01_schema.sql        # Khởi tạo bảng, khóa chính, khóa ngoại[cite: 1]
    │   ├── 02_data.sql          # Dữ liệu mẫu có ý nghĩa (tối thiểu 5 dòng/bảng)[cite: 1]
    │   ├── 03_procedures.sql    # Stored Procedures cho Insert, Update, Delete[cite: 1]
    │   ├── 04_triggers.sql      # Triggers cho ràng buộc nghiệp vụ & băm mật khẩu[cite: 1]
    │   └── 05_functions.sql     # Functions chứa IF/LOOP và Cursors[cite: 1]
    ├── docs/                    # Tài liệu đặc tả chi tiết dự án (Markdown)[cite: 1]
    │   ├── API_SPEC.md          # Đặc tả các đầu Endpoint và mã lỗi[cite: 1]
    │   ├── DATABASE_SPEC.md     # Đặc tả ERD và các Business Rules[cite: 1]
    │   └── DEVELOPMENT_GUIDE.md # Hướng dẫn thiết lập môi trường và Git[cite: 1]
    ├── src/                     # Thư mục mã nguồn chính của ứng dụng FastAPI[cite: 1]
    │   ├── main.py              # File khởi chạy chính, khai báo FastAPI app[cite: 1]
    │   ├── core/                # Cấu hình hệ thống chung[cite: 1]
    │   │   └── config.py        # Đọc biến môi trường từ .env (DB_PASSWORD, DB_NAME)[cite: 1]
    │   ├── db/                  # Tầng kết nối trực tiếp với Database[cite: 1]
    │   │   ├── session.py       # Quản lý Connection Pool đến MySQL[cite: 1]
    │   │   └── base.py          # Chứa các hàm thực thi gọi Stored Procedure[cite: 1]
    │   ├── schemas/             # Pydantic models để validate dữ liệu API[cite: 1]
    │   │   ├── task.py          # Schema cho Task (Title, Priority, DueDate...)[cite: 1]
    │   │   └── user.py          # Schema cho User và Profile[cite: 1]
    │   ├── crud/                # Logic xử lý nghiệp vụ thông qua Procedure[cite: 1]
    │   │   ├── crud_task.py     # Chỉ chứa các lệnh CALL sp_create_task, sp_update_task...[cite: 1]
    │   │   └── crud_user.py     # Xử lý login, profile thông qua Procedure[cite: 1]
    │   ├── api/                 # Tầng định tuyến (Routing)[cite: 1]
    │   │   ├── endpoints/       # Chi tiết các API theo từng module[cite: 1]
    │   │   │   ├── tasks.py     # API cho các thao tác về Task[cite: 1]
    │   │   │   └── users.py     # API cho các thao tác về User[cite: 1]
    │   │   └── api_router.py    # Gộp tất cả router lại một mối[cite: 1]
    │   └── static/              # Tài nguyên Frontend (Giao diện người dùng)[cite: 1]
    │       ├── index.html       # UI chính (Được sinh bởi Prompt AI)[cite: 1]
    │       └── script.js        # Logic gọi API từ trình duyệt[cite: 1]
    ├── .env                     # Lưu thông tin nhạy cảm (User, Password)[cite: 1]
    ├── .env.example             # File mẫu hướng dẫn cấu hình cho đồng đội[cite: 1]
    ├── .gitignore               # Chặn các file rác (venv, .env, __pycache__)[cite: 1]
    ├── docker-compose.yml       # (Đã có) Cấu hình Docker cho MySQL 8.0[cite: 1]
    └── requirements.txt         # Danh sách thư viện (fastapi, mysql-connector...)[cite: 1]
